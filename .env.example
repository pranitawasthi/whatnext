APP_ENV=development
DATABASE_URL=sqlite+aiosqlite:///./whatnext.db
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=content_embeddings
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Embeddings are local sentence-transformers vectors. BAAI/bge-small-en-v1.5 outputs 384 dimensions.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# Explanations prefer Groq when configured, otherwise OpenAI chat if configured, otherwise a deterministic fallback.
GROQ_API_KEY=
EXPLANATION_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=

VITE_API_URL=http://localhost:8000
